# Test wallet — copy to examples/.env and fill in your values
# DO NOT COMMIT .env
#
# Generate a fresh wallet:
#   cast wallet new --json | node -e \
#     "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); \
#     console.log('PRIVATE_KEY='+d[0].private_key+'\nTEST_ADDRESS='+d[0].address);" \
#     > examples/.env
#
# Then fund TEST_ADDRESS with GNUS on each chain you want to test.

PRIVATE_KEY=0x<64hexchars>
TEST_ADDRESS=0x<40hexchars>

# Optional RPC overrides (defaults to public endpoints)
#RPC_SEPOLIA=https://your-node.example.com
